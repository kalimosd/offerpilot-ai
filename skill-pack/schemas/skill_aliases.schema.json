{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offerpilot.local/schemas/skill_aliases.schema.json",
  "title": "OfferPilot Skill Aliases",
  "type": "object",
  "minProperties": 1,
  "propertyNames": {
    "type": "string",
    "minLength": 1,
    "pattern": "^[a-z0-9][a-z0-9+./ ()-]*$"
  },
  "additionalProperties": {
    "type": "array",
    "minItems": 1,
    "items": {
      "type": "string",
      "minLength": 1
    },
    "uniqueItems": true
  }
}
