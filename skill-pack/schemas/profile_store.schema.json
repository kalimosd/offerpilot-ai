{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offerpilot.local/schemas/profile_store.schema.json",
  "title": "OfferPilot Profile Store",
  "type": "object",
  "required": ["meta"],
  "additionalProperties": true,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "name_en": { "type": "string" },
        "birth_year": {
          "type": ["integer", "null"],
          "minimum": 1900,
          "maximum": 2100
        },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "updated": { "type": "string" }
      }
    },
    "experience": {
      "type": "array",
      "items": { "$ref": "#/$defs/experienceEntry" }
    },
    "projects": {
      "type": "array",
      "items": { "$ref": "#/$defs/projectEntry" }
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skillEntry" }
    },
    "education": {
      "type": "array",
      "items": { "$ref": "#/$defs/educationEntry" }
    },
    "certifications": { "type": "array" },
    "achievements": { "type": "array" }
  },
  "$defs": {
    "experienceEntry": {
      "type": "object",
      "required": ["company", "role", "start", "end", "bullets"],
      "additionalProperties": true,
      "properties": {
        "company": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "start": { "type": "string", "minLength": 1 },
        "end": { "type": "string", "minLength": 1 },
        "bullets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bullet" }
        }
      }
    },
    "projectEntry": {
      "type": "object",
      "required": ["name", "bullets"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "context": { "type": "string" },
        "link": { "type": "string" },
        "category": { "type": "string" },
        "bullets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bullet" }
        }
      }
    },
    "bullet": {
      "type": "object",
      "required": ["text", "tags"],
      "additionalProperties": true,
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "impact": {
          "type": "string",
          "enum": ["quantified", "qualitative", "context-only"]
        },
        "variants": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "ref": { "type": "string" }
      }
    },
    "skillEntry": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "level": {
          "type": "string",
          "enum": ["familiar", "proficient", "expert"]
        },
        "years": { "type": "number", "minimum": 0 },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "educationEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "school": { "type": "string" },
        "degree": { "type": "string" },
        "major": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" }
      }
    }
  }
}
